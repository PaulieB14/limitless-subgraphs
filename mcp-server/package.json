{
  "name": "limitless-mcp",
  "version": "1.0.0",
  "description": "MCP server for Limitless prediction market analytics — combines on-chain subgraph data with market metadata",
  "type": "module",
  "bin": {
    "limitless-mcp": "build/index.js"
  },
  "main": "./build/index.js",
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "limitless",
    "prediction-market",
    "thegraph",
    "subgraph",
    "base"
  ],
  "author": "PaulieB14",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
